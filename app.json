{
  "expo": {
    "name": "지원금 모아보기",
    "slug": "jiwongum",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "jiwongum",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jiwongum.app"
    },
    "android": {
      "package": "com.jiwongum.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#154c76",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "com.google.android.gms.permission.AD_ID",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8785405056367250~4012448499",
          "iosAppId": "ca-app-pub-8785405056367250~1027458434"
        }
      ],
      "expo-web-browser",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "맞춤형 광고 제공을 위해 기기 활동 데이터 사용에 동의해 주세요."
        }
      ],
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#154c76"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "backgroundColor": "#154c76",
          "dark": {
            "image": "./assets/splash-icon.png",
            "imageWidth": 220,
            "backgroundColor": "#0c1116"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "55a524eb-4738-421c-b9da-9b49729b81b0"
      }
    }
  }
}
